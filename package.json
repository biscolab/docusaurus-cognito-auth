{
  "name": "docusaurus-cognito-auth",
  "version": "1.0.0",
  "description": "Serverless authentication layer (Lambda@Edge + Cognito) for static sites",
  "type": "module",
  "workspaces": [
    "src/auth-check",
    "src/auth-callback"
  ],
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:config": "node scripts/build-config.mjs",
    "build": "npm run build:config && sam build",
    "deploy": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jose": "^5.0.0",
    "prettier": "^3.0.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT"
}
