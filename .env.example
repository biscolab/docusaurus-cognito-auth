# Copy this file to .env and fill in your values.
# These are used by scripts/build-config.mjs to generate the Lambda config files.
# Never commit .env to version control.

AWS_REGION=us-east-1
USER_POOL_ID=us-east-1_XXXXXXXXX
CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=your-prefix.auth.us-east-1.amazoncognito.com
# Fill this in after the first deploy (use the CloudFront domain from Outputs)
CALLBACK_URL=https://XXXXXXXXXXXX.cloudfront.net/callback
